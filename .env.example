# --- Model ---
# Either point MODEL_PATH at a local .gguf file, OR leave it blank and set
# MODEL_REPO / MODEL_FILE so the service downloads the file from Hugging Face
# on first startup (cached under ~/.cache/huggingface).
MODEL_PATH=
MODEL_REPO=Qwen/Qwen3-Embedding-0.6B-GGUF
# Available files in this repo are Q8_0 and f16.
# Q8_0 (~650 MB) is the default; use f16 (~1.2 GB) for reference quality.
MODEL_FILE=Qwen3-Embedding-0.6B-Q8_0.gguf

# Context window the model was exported with (Qwen3-Embedding = 32768).
# Lower values use less RAM.
N_CTX=8192

# Threads for CPU inference. 0 = let llama.cpp pick based on cores.
N_THREADS=0

# GPU offload. On Apple Silicon llama-cpp-python auto-builds with Metal, so
# any non-zero value offloads to the GPU. -1 = all layers. Set to 0 to force CPU.
N_GPU_LAYERS=-1

# Batch size for the prompt/compute graph.
N_BATCH=512

# --- Server ---
APP_ENV=dev
ALLOWED_ORIGINS=["*"]

# --- Request limits (DOS guards) ---
# Maximum number of strings in a single /v1/embed request.
MAX_INPUTS_PER_REQUEST=256
# Maximum characters per individual input string.
MAX_CHARS_PER_INPUT=200000

# --- Auth (Tapis) ---
# All endpoints except /healthz require a valid X-Tapis-Token from this tenant.
TAPIS_ISSUER=https://icicleai.tapis.io/v3/tokens
TAPIS_JWKS_URL=https://icicleai.tapis.io/v3/tokens/.well-known/jwks.json
TAPIS_TENANT_ID=icicleai
