# --- Model ---
MODEL_PATH=
MODEL_REPO=Qwen/Qwen3-Embedding-0.6B-GGUF
MODEL_FILE=Qwen3-Embedding-0.6B-Q8_0.gguf

N_CTX=8192
N_THREADS=0
N_GPU_LAYERS=-1
N_BATCH=512

# --- Server ---
APP_ENV=dev
ALLOWED_ORIGINS=["*"]

# --- Request limits (DOS guards) ---
MAX_INPUTS_PER_REQUEST=256
MAX_CHARS_PER_INPUT=200000

# --- Auth (Tapis) ---
TAPIS_ISSUER=https://icicleai.tapis.io/v3/tokens
TAPIS_JWKS_URL=https://icicleai.tapis.io/v3/tokens/.well-known/jwks.json
TAPIS_TENANT_ID=icicleai

# --- Cache (Redis, optional & fail-open) ---
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT_SECONDS=0.5
CACHE_TTL_SECONDS=2592000
CACHE_KEY_PREFIX=emb:v1:
REDIS_MAXMEMORY=2gb
REDIS_MAXMEMORY_POLICY=allkeys-lru
